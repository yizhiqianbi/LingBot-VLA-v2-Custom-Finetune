states:
  - observation.state.arm.position:
      origin_keys:
        - observation.state:
            start: 0
            end: 7
  - observation.state.effector.position:
      origin_keys:
        - observation.state:
            start: 14
            end: 15

actions:
  - action.arm.position:
      origin_keys:
        - action:
            start: 0
            end: 7
      subtract_state: true
      relative_type: joint
  - action.effector.position:
      origin_keys:
        - action:
            start: 14
            end: 15
      subtract_state: false

images:
  - observation.images.camera_top:
      origin_keys: observation.images.left_eye
  - observation.images.camera_wrist_left:
      origin_keys: observation.images.right_eye
  - observation.images.camera_wrist_right:
      origin_keys: observation.images.right_wrist

norm_stats: ${NORM_STATS_PATH}
